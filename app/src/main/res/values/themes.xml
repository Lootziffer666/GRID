<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        The full Compose theme lives in PainkillerTheme.kt. This XML theme is
        only used for the Activity's window background before Compose draws
        its first frame.
    -->
    <style name="Theme.Painkiller" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/painkiller_dark_background</item>
        <item name="android:statusBarColor">@color/painkiller_dark_background</item>
    </style>
</resources>
